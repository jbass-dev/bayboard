rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    // Role is carried as a custom claim set by the setUserRole Cloud Function.
    function isManager() { return signedIn() && request.auth.token.role == 'manager'; }

    // MVP + public demo: any signed-in user (including anonymous guests) can
    // read and write, so a visitor can load demo data and drive every feature.
    // Role gating currently lives in the UI (route guards + nav) and in the
    // setUserRole callable, which enforces manager-only server-side.
    match /{document=**} {
      allow read, write: if signedIn();
    }

    // Production hardening (for reference): once real staff accounts exist and
    // the open demo is retired, scope writes by role with isManager(), e.g.
    // only managers may edit scheduling and staff records:
    //
    //   match /shiftRequirements/{id} { allow read: if signedIn(); allow write: if isManager(); }
    //   match /shiftAssignments/{id}  { allow read: if signedIn(); allow write: if isManager(); }
    //   match /technicians/{id}       { allow read: if signedIn(); allow write: if isManager(); }
  }
}
